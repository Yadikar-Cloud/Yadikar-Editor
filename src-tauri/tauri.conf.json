{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Yadikar-Editor",
  "version": "3.3.1",
  "identifier": "it.yadikar.editor",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Yadikar Text Editor",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../src/assets/image/yadikar-editor-64x64.png",
      "../src/assets/image/yadikar-editor-128x128.png",
      "../src/assets/image/yadikar-editor-256x256.png",
      "../src/assets/image/yadikar-editor.ico"
    ]
  }
}
